{
  "name": "enhanced-google-search-mcp",
  "version": "2.0.0",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/server.ts",
    "dev": "fastmcp dev src/server.ts",
    "lint": "prettier --check . && eslint . && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write . && eslint --fix ."
  },
  "keywords": [
    "fastmcp",
    "mcp",
    "google-search",
    "web-search",
    "anonymization",
    "anti-detection"
  ],
  "repository": {
    "url": "https://github.com/your-username/enhanced-google-search-mcp"
  },
  "author": "Your Name <your.email@example.com>",
  "type": "module",
  "license": "MIT",
  "description": "Enhanced Google search MCP server with advanced anonymization and anti-detection features",
  "dependencies": {
    "axios": "^1.7.9",
    "axios-retry": "^4.5.0",
    "cheerio": "^1.0.0-rc.12",
    "fastmcp": "^1.27.3",
    "random-useragent": "^0.5.0",
    "zod": "^3.24.4"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@tsconfig/node22": "^22.0.1",
    "@types/axios": "^0.14.4",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^22.10.5",
    "eslint-config-prettier": "^10.1.3",
    "eslint-plugin-perfectionist": "^4.12.3",
    "jiti": "^2.4.2",
    "prettier": "^3.5.3",
    "semantic-release": "^24.2.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vitest": "^3.1.3"
  }
}
